generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  deposit
  withdrawal
  reinvestment
}

model Transaction {
  id     String          @id @default(uuid())
  date   String
  amount Float
  type   TransactionType
}

model Prize {
  id     String @id @default(uuid())
  date   String
  amount Float
}
